# Vercel Blob storage token
BLOB_READ_WRITE_TOKEN=

# Vercel KV (Redis) credentials — auto-populated by Vercel dashboard
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Shared secret for Pi → Vercel authentication
# Generate with: openssl rand -hex 32
API_SECRET=

# HLS stream URL from Tailscale Funnel (set in Vercel dashboard too)
NEXT_PUBLIC_STREAM_URL=https://{pi-hostname}.{tailnet}.ts.net/hls/stream.m3u8
